{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "epran-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/epran-frontend",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/manifest.webmanifest"
            ],
            "styles": [
              "node_modules/material-icons/iconfont/material-icons.css",
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/maplibre-gl/dist/maplibre-gl.css",
              "src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1MB", "maximumError": "3MB" },
                { "type": "anyComponentStyle", "maximumWarning": "20kB", "maximumError": "30kB" }
              ],
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json",
              "optimization": {
                "scripts": true,
                "fonts": true,
                "styles": { "minify": true, "inlineCritical": false }
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "epran-frontend:build:production" },
            "development": { "buildTarget": "epran-frontend:build:development" }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "proxy.conf.json"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "76e925c9-4151-43cc-9f4f-2b172b690a3e"
  }
}
