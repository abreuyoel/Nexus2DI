# Copiar a .env para desarrollo local. En producción (k8s) estas mismas
# claves se cargan vía ConfigMap (no-secretas) + Secret (secretas) — ver
# ../k8s/configmap-backend.yaml y ../k8s/secret-backend.example.yaml.
# Nunca commitear un .env real.

# --- Secretos (sin default en config.py, obligatorios) ---
SECRET_KEY=genera_con_openssl_rand_hex_64
DB_USER=dev
DB_PASSWORD=CHANGE_ME

# --- No secretos ---
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=172.174.41.110
DB_NAME=epran-qa
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

ENVIRONMENT=development

REDIS_HOST=localhost
REDIS_PORT=6379

AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=epran
AZURE_ACCOUNT_NAME=saeprandat001

VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:admin@epran.com

SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_TIMEZONE=America/Caracas

FRONTEND_URL=http://localhost:4200
